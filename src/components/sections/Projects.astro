---
import type { Resume } from "@/content/config";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import GitHub from "@/icons/GitHub.astro";

const { data } = Astro.props;
const { projects } = data as Resume;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<ul>
    {
        projects.map(
            ({ url, description, highlights, name, isActive, github, startDate, endDate, storeLinks }) => (
                <li>
                    <article>
                        <header>
                            <h3>
                                <a
                                    href={url}
                                    title={`${t("projects.link")} ${name}`}
                                    target="_blank"
                                >
                                    {name}
                                </a>
                                {isActive && <span>&bull;</span>}
                                {github && (
                                    <a
                                        class="github-code-link"
                                        href={github}
                                        target="_blank"
                                        title={`${t("projects.sourceCode")} ${name}${t("projects.sourceCodeFollowing")}`}
                                    >
                                        <GitHub />
                                    </a>
                                )}
                            </h3>
                            {startDate && (
                                <time class="project-date">
                                    {new Date(`${startDate}T00:00:00-06:00`).getFullYear()}
                                    {" — "}
                                    {endDate != null ? new Date(`${endDate}T00:00:00-06:00`).getFullYear() : t("projects.present")}
                                </time>
                            )}
                            <p>{description}</p>
                        </header>
                        <footer>
                            {highlights.map((highlight) => (
                                <span>{highlight}</span>
                            ))}
                            {storeLinks && storeLinks.length > 0 && (
                                <div class="store-links">
                                    {storeLinks.map(({ store, url: storeUrl }) => (
                                        <a
                                            class="store-link"
                                            href={storeUrl}
                                            target="_blank"
                                            title={`${t("projects.downloadOn")} ${store}`}
                                        >
                                            {store}
                                        </a>
                                    ))}
                                </div>
                            )}
                        </footer>
                    </article>
                </li>
            ),
        )
    }
</ul>

<style>
    .github-code-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 13px;
        width: 13px;
        transition: all 0.2s ease;
        margin-left: 4px;
    }

    .github-code-link:hover {
        transform: scale(1.1);
    }

    ul {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1rem;
        margin-inline: -16px;
    }

    @keyframes pulse {
        0%,
        100% {
            opacity: 1;
        }
        50% {
            opacity: 0.5;
        }
    }

    article {
        border-radius: 8px;
        border: 1px solid var(--projects-background);
        gap: 16px;
        display: flex;
        flex-direction: column;
        padding: 16px;
        height: 100%;
    }

    article header {
        flex: 1;
    }

    article h3 {
        margin-bottom: 4px;
        font-weight: 600;
    }

    article h3 span {
        color: var(--projects-active);
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        margin-left: 2px;
    }

    article p {
        font-size: 0.75rem;
        line-height: 1.2rem;
        margin-bottom: 8px;
    }

    article a {
        color: var(--black-text);
    }

    article a:hover {
        text-decoration: underline;
    }

    footer {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        font-size: 0.6rem;
    }

    footer span {
        border-radius: 6px;
        background: var(--hover-background);
        color: var(--secondary-text);
        font-size: 0.6rem;
        font-weight: 500;
        padding: 0.2rem 0.6rem;
    }

    .project-date {
        display: block;
        font-size: 0.7rem;
        color: var(--secondary-text);
        margin-bottom: 6px;
    }

    .store-links {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        margin-top: 4px;
        width: 100%;
    }

    .store-link {
        border-radius: 6px;
        border: 1px solid var(--projects-background);
        color: var(--secondary-text) !important;
        font-size: 0.6rem;
        font-weight: 600;
        padding: 0.2rem 0.6rem;
        text-decoration: none !important;
        transition: all 0.2s ease;
    }

    .store-link:hover {
        background: var(--hover-background);
        text-decoration: none !important;
    }
</style>